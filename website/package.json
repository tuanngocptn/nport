{
  "name": "nport-site",
  "version": "1.0.0",
  "description": "the website for nport tool",
  "main": "script.js",
  "scripts": {
    "build:css": "npx tailwindcss -i ./assets/css/input.css -o ./assets/css/style.css --minify",
    "dev:css": "npx tailwindcss -i ./assets/css/input.css -o ./assets/css/style.css --watch",
    "build": "npm run build:css && node minify.js",
    "minify": "node minify.js",
    "dev": "npm run dev:css",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "tuanngocptn",
  "license": "ISC",
  "devDependencies": {
    "clean-css": "^5.3.3",
    "html-minifier": "^4.0.0",
    "tailwindcss": "^3.4.19",
    "terser": "^5.37.0"
  }
}
